"""{title} — fetcher auto-généré (template csv_dump).

Source : {source_id}
URL : {endpoint}
Licence : {license}
Télécharge un fichier CSV (éventuellement .gz) et stream dans bronze.
Auto-généré par codegen template-first.
"""
from __future__ import annotations

import csv
import gzip
import hashlib
import io
import json
import logging
from datetime import datetime, timezone

import httpx
import psycopg
from psycopg.types.json import Jsonb

from config import settings

log = logging.getLogger(__name__)

ENDPOINT = "{endpoint}"
BATCH_SIZE = {batch_size}
MAX_ROWS = {max_rows}


async def fetch_{source_id}_delta() -> dict:
    """Stream CSV download + batch INSERT."""
    if not settings.database_url:
        return {{"source": "{source_id}", "rows": 0, "error": "no DB"}}

    total_inserted = 0
    total_processed = 0
    errors = 0

    async with httpx.AsyncClient(timeout=3600, follow_redirects=True,
                                  headers={{"User-Agent": "DEMOEMA-Agents/0.1"}}) as client:
        async with client.stream("GET", ENDPOINT) as resp:
            if resp.status_code != 200:
                return {{"source": "{source_id}", "rows": 0, "error": f"HTTP {{resp.status_code}}"}}

            # Détecter gzip UNIQUEMENT via extension URL
            # (httpx décompresse déjà Content-Encoding: gzip côté transport)
            is_gz = ENDPOINT.lower().split("?")[0].endswith(".gz")

            # Collecter tout le bytes d'abord (pour CSV < 500MB)
            chunks = []
            async for chunk in resp.aiter_bytes(1024 * 1024):
                chunks.append(chunk)
            data = b"".join(chunks)
            if is_gz:
                try:
                    data = gzip.decompress(data)
                except Exception as e:
                    return {{"source": "{source_id}", "rows": 0, "error": f"gunzip: {{e}}"}}
            try:
                text = data.decode("utf-8")
            except UnicodeDecodeError:
                text = data.decode("latin-1", errors="replace")

            # Détection auto du délimiteur
            sample = text[:4096]
            try:
                delim = csv.Sniffer().sniff(sample, delimiters=",;|\t").delimiter
            except Exception:
                delim = ","

            async with await psycopg.AsyncConnection.connect(settings.database_url) as conn:
                async with conn.cursor() as cur:
                    reader = csv.DictReader(io.StringIO(text), delimiter=delim)
                    batch = []
                    for row in reader:
                        total_processed += 1
                        if total_processed > MAX_ROWS:
                            break
                        # Cascade clé : key_field → id → 1re colonne non vide → SHA1 du payload
                        key_val = (row.get("{key_field}") or row.get("id")
                                   or next((v for v in row.values() if v and str(v).strip()), None))
                        if not key_val:
                            key_val = hashlib.sha1(
                                json.dumps(row, sort_keys=True, default=str).encode()
                            ).hexdigest()[:32]
                        key_str = str(key_val)[:128]
                        batch.append((key_str, Jsonb(row), datetime.now(tz=timezone.utc)))
                        if len(batch) >= BATCH_SIZE:
                            try:
                                await cur.executemany(
                                    """
                                    INSERT INTO {table} ({key_field}, payload, ingested_at)
                                    VALUES (%s, %s, %s)
                                    ON CONFLICT ({key_field}) DO NOTHING
                                    """,
                                    batch,
                                )
                                total_inserted += cur.rowcount or 0
                                await conn.commit()
                            except Exception as e:
                                log.warning("batch fail: %s", e)
                                errors += len(batch)
                            batch.clear()
                    if batch:
                        try:
                            await cur.executemany(
                                """
                                INSERT INTO {table} ({key_field}, payload, ingested_at)
                                VALUES (%s, %s, %s)
                                ON CONFLICT ({key_field}) DO NOTHING
                                """,
                                batch,
                            )
                            total_inserted += cur.rowcount or 0
                            await conn.commit()
                        except Exception as e:
                            errors += len(batch)

    return {{
        "source": "{source_id}",
        "rows": total_inserted,
        "fetched": total_processed,
        "errors": errors,
        "mode": "csv_stream",
    }}
