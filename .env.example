# ========= Caddy / domain =========
# Domaine public (A record pointant vers l'IP du VPS Hetzner)
DOMAIN=demomea.votre-domaine.com

# ========= Pappers (données entreprises FR) =========
PAPPERS_MCP_URL=https://mcp.pappers.fr/REMPLACEZ_PAR_VOTRE_TOKEN

# ========= DeepSeek LLM =========
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ========= CORS (origines autorisées pour le front) =========
# Liste d'origines explicites, séparées par des virgules
CORS_ORIGINS=https://demomea.votre-domaine.com
# Regex de fallback (par défaut : Vercel + Cloudflare Workers + Pages)
# CORS_ORIGIN_REGEX=https://.*\.(vercel\.app|workers\.dev|pages\.dev)$

# ========= Cloudflare R2 (datalake, optionnel) =========
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=demomea-datalake
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ========= Postgres datalake (REQUIS pour silver/bronze pipelines) =========
# Source-of-truth UNIQUE : ce password initialise datalake-db ET dérive
# DATABASE_URL côté agents-platform via interpolation Compose. Ne JAMAIS
# avoir DATABASE_URL et ce password en mismatch.
# Génération suggérée : openssl rand -hex 24
DATALAKE_POSTGRES_ROOT_PASSWORD=
DATALAKE_AGENTS_PASSWORD=
DATALAKE_RO_PASSWORD=

# Optionnel — override la DSN auto-construite par config.py si tu pointes
# vers un Postgres externe (Supabase managed, RDS, etc.). Si vide, la DSN
# est dérivée de DATALAKE_POSTGRES_ROOT_PASSWORD + datalake-db:5432/datalake.
# DATABASE_URL=postgresql://user:pwd@host:5432/db
