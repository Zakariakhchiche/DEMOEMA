# ============================================================================
# DEMOEMA - Déploiement VPS (Docker compose + Caddy)
# Copier vers .env et remplir les secrets.
# ============================================================================

# --- Caddy / domaine ---
# Doit pointer vers l'IP publique du VPS (A record DNS).
DOMAIN=demoema.votre-domaine.com

# --- Supabase (cache persistant + Postgres) ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...

# --- MotherDuck (DuckDB cloud, Bronze/Silver SIRENE 16M) ---
MOTHERDUCK_TOKEN=

# --- AI Gateway Vercel (LLM principal copilot) ---
AI_GATEWAY_API_KEY=

# --- DeepSeek (legacy LLM, optionnel) ---
DEEPSEEK_API_KEY=

# --- Secrets admin / cron ---
ADMIN_SECRET=changeme-long-random-string
CRON_SECRET=changeme-long-random-string

# --- INPI RNE (enrichissement dirigeants, optionnel) ---
INPI_USER=
INPI_PASSWORD=

# --- Postgres direct (optionnel, si vous n'utilisez pas Supabase REST) ---
DATABASE_URL=

# --- Pappers MCP (legacy, optionnel) ---
PAPPERS_MCP_URL=

# --- Cloudflare R2 datalake (optionnel) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=demoema-datalake
R2_ENDPOINT=
