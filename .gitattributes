# Normalize line endings to LF across platforms
* text=auto eol=lf

# Explicit LF for source code
*.py         text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
*.json       text eol=lf
*.jsonc      text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
*.sql        text eol=lf
*.css        text eol=lf
*.html       text eol=lf
Dockerfile   text eol=lf
Caddyfile    text eol=lf
.env.example text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.parquet    binary
