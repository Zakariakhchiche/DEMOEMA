{$DOMAIN:localhost} {
    encode zstd gzip

    # Bug 3.3 rapport QA v4 — headers sécu HTTP
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
        # Désactive le header serveur pour éviter le fingerprinting (bug v6/1.3)
        -Server
        -X-Powered-By
    }

    # Bug v6/1.8 — rate limiting non effectif : Caddy ne forwarde pas l'IP
    # cliente au backend. Sans X-Real-IP, slowapi voit 127.0.0.1 partout
    # et le rate limit s'applique globalement (jamais déclenché ou quasi).
    handle /api/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {http.request.remote.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up X-Real-IP {http.request.remote.host}
            header_up X-Forwarded-For {http.request.remote.host}
        }
    }

    log {
        output stdout
        format console
    }
}

studio.{$DOMAIN:localhost} {
    encode zstd gzip

    basic_auth {
        admin $2a$14$XT84OloZ/9o6i0khB2Av0eZa1FKFxPK5SgZG1BOj2NXYxgG.u/58a
    }

    reverse_proxy supabase-studio:3000

    log {
        output stdout
        format console
    }
}

grafana.{$DOMAIN:localhost} {
    encode zstd gzip

    reverse_proxy demomea-grafana:3000

    log {
        output stdout
        format console
    }
}
